# ── Required ──────────────────────────────────────────────────────────────────

# Your Discord bot token (from discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token-here

# Your Discord user ID — only this user can run /mee admin commands
OWNER_ID=123456789012345678

# ── Security ──────────────────────────────────────────────────────────────────

# Fernet key used to encrypt user API keys at rest in the database.
# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left blank, keys are stored unencrypted (not recommended for production).
SECRET_KEY=

# ── Server-level fallback LLM (optional) ──────────────────────────────────────

# BACKGROUND (idle/ambient) key — Groq. Fast, high-volume (14,400 req/day free).
# If set, users who run /mymee create do NOT need to provide their own API key.
OWNER_API_KEY=
OWNER_API_BASE=https://api.groq.com/openai/v1
OWNER_API_MODEL=llama-3.1-8b-instant

# FOREGROUND (direct user + Mee-to-Mee responses) key — Google AI Studio.
# Gemini 2.0 Flash gives dramatically better roleplay quality for spoken conversations.
# Free tier: https://aistudio.google.com — key starts with AIza...
# If set, all Mees will use Gemini for any message that is a direct reply to a user
# or a targeted Mee-to-Mee conversation. Falls back to OWNER_API_KEY if not set.
OWNER_GEMINI_API_KEY=
OWNER_GEMINI_MODEL=gemini-2.0-flash

# ── Multi-user config ─────────────────────────────────────────────────────────

# How many Mees a single Discord user can create via /mymee create
MAX_MEES_PER_USER=1

# Optional: Discord role ID required to use /mymee create
# Leave blank to allow all server members.
REQUIRE_ROLE_ID=

# ── Tick tuning ───────────────────────────────────────────────────────────────

# Base interval between a Mee's autonomous actions (minutes)
# Reduced by up to 50% when channel excitement is high, and scaled by time of day.
TICK_INTERVAL_MIN=3

# Hard minimum gap between any two messages from the same Mee (minutes)
# Prevents flooding during high-excitement periods.
SPOKE_COOLDOWN_MIN=4

# Maximum LLM API calls allowed per agent per tick.
# Keeps Groq free-tier users comfortably within limits.
MAX_CALLS_PER_TICK=8

# Minimum minutes between autonomous location changes (wandering).
# Prevents movement spam when LLM is unavailable or rate-limited.
WANDER_COOLDOWN_MINUTES=30

# ── Daily rhythm ──────────────────────────────────────────────────────────────

# Hour (0-23 local server time) when Mees go to sleep (slower tick, sleep context)
SLEEP_HOUR_START=23

# Hour (0-23 local server time) when Mees wake up
SLEEP_HOUR_END=7

# ── Memory & reflection ───────────────────────────────────────────────────────

# Cumulative importance sum before a reflection cycle fires.
# Lower = more frequent reflections.
REFLECTION_THRESHOLD=150

# ── Storage ───────────────────────────────────────────────────────────────────

# Path to the SQLite database file (inside Docker, /data is a named volume)
DB_PATH=/data/meebot.db

# ── Logging ───────────────────────────────────────────────────────────────────

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
